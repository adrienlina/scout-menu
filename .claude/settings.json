{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit*)",
            "command": "npm run lint --silent >&2 || { echo 'Pre-commit lint check failed. Run `npm run lint` to see errors.' >&2; exit 2; }",
            "timeout": 120,
            "statusMessage": "Running pre-commit lint…"
          }
        ]
      }
    ]
  }
}
