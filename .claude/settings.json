{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit*)",
            "command": "npm run lint --silent >&2 || { echo 'Pre-commit lint check failed. Run `npm run lint` to see errors.' >&2; exit 2; }",
            "timeout": 120,
            "statusMessage": "Running pre-commit lint…"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "mcp__github__create_pull_request",
        "hooks": [
          {
            "type": "mcp_tool",
            "server": "github",
            "tool": "subscribe_pr_activity",
            "input": {
              "owner": "${tool_input.owner}",
              "repo": "${tool_input.repo}",
              "pullNumber": "${tool_response.number}"
            },
            "statusMessage": "Subscribing to PR activity for autofix…"
          }
        ]
      }
    ]
  }
}
